      "parameters": {
        "jsCode": "const binary = $input.item.binary ?? {};\n\nconst allowedMimeTypes = new Set([\n  'image/jpeg',\n  'image/png',\n  'image/webp',\n  'application/pdf',\n]);\n\nconst attachmentKeys = Object.keys(binary).filter((key) => {\n  const file = binary[key];\n  return file && allowedMimeTypes.has(file.mimeType);\n});\n\nif (attachmentKeys.length === 0) {\n  throw new Error(\n    'No receipt image or PDF found in email. Expected a downloaded Gmail attachment in binary data such as attachment_0 or attachment_1.'\n  );\n}\n\n// Pick the first supported attachment\nconst attachmentKey = attachmentKeys[0];\nconst file = binary[attachmentKey];\n\nreturn [\n  {\n    json: {\n      attachmentProperty: attachmentKey,\n      mimeType: file.mimeType || null,\n      fileName: file.fileName || null,\n      isPdf: file.mimeType === 'application/pdf',\n    },\n    binary: {\n      [attachmentKey]: file,\n    },\n  },\n];"
      },
